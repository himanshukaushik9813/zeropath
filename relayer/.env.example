# ZeroPath relayer configuration.

# Expose the pre-seeded demo secrets endpoint (hackathon only).
ZEROPATH_DEMO_MODE=true

# --- On-chain settlement (POST /v1/settle) ---
# When these are set, the relayer submits browser/SDK-generated proofs to the
# deployed settlement contract via the `stellar` CLI, verifying them on-chain.
# Leave unset to disable on-chain settlement (proofs still verify in-browser).

# Deployed settlement contract id (from deploy-testnet.sh).
# ZEROPATH_CONTRACT_ID=C...
# Payout token (SAC) contract id — the settlement contract must hold a balance.
# ZEROPATH_SETTLE_TOKEN=C...
# Address that receives the settled funds.
# ZEROPATH_SETTLE_RECIPIENT=G...

# Optional overrides:
# ZEROPATH_STELLAR_IDENTITY=zeropath-deployer   # must be the contract's registered relayer
# ZEROPATH_NETWORK=testnet
# ZEROPATH_SETTLE_AMOUNT=5000

# --- Real cross-chain source (Ethereum Sepolia) ---
# When set, the relayer builds the SOURCE Merkle tree from REAL on-chain deposits
# in the ZeroPathSepoliaEscrow contract instead of simulated demo leaves.
# Leave unset to use demo leaves.
# ZEROPATH_ETH_RPC=https://ethereum-sepolia-rpc.publicnode.com
# ZEROPATH_ETH_ESCROW=0x...   # deployed ZeroPathSepoliaEscrow address
